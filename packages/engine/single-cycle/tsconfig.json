{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist"
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../../isa" },
    { "path": "../../trace" },
    // Test-only edges. `assembler` + `common` (toProgramImage) are used only by this engine's
    // tests — production code consumes the pure ProgramImage. `conformance` is the shared INV-8
    // differential harness (it pulls in the golden reference itself), so this engine no longer
    // references `../reference` directly.
    { "path": "../../assembler" },
    { "path": "../common" },
    { "path": "../conformance" }
  ]
}
