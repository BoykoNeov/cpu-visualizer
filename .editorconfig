root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

# Windows batch files must stay CRLF. cmd.exe tolerates LF for plain sequential lines but
# mis-parses `for /f` loops and parenthesized `if (...)` blocks - it runs REM lines as
# commands and expands %VARS% set inside them to nothing. "Start CPU Visualizer.bat" needs
# both constructs to find and reuse a running dev server, so saving it as LF silently sends
# it back to starting a duplicate server on every double-click. Mirrors the *.bat rule in
# .gitattributes - change both together.
[*.{bat,cmd}]
end_of_line = crlf
