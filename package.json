{
  "name": "cpu-visualizer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A pedagogical RISC-V (RV32I) processor simulator: load and run programs and watch how a CPU actually works across a family of microarchitectures.",
  "license": "BNCL-1.0",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/isa",
    "packages/trace",
    "packages/assembler",
    "packages/curriculum",
    "packages/engine/common",
    "packages/engine/conformance",
    "packages/engine/reference",
    "packages/engine/single-cycle",
    "packages/engine/multi-cycle",
    "packages/engine/pipeline",
    "packages/web"
  ],
  "scripts": {
    "build": "tsc -b && npm run build --workspace @cpu-viz/web",
    "typecheck": "tsc -b && npm run typecheck --workspace @cpu-viz/web",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "npm run dev --workspace @cpu-viz/web",
    "clean": "tsc -b --clean",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/node": "^22.13.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.19.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.22.0",
    "vite": "^6.0.11",
    "vitest": "^3.0.4"
  }
}
